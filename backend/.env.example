# ---- Hyperswitch sandbox credentials ----
# Get these from the Hyperswitch dashboard (sandbox): Developers -> API Keys
# Secret/API key. SERVER-SIDE ONLY. Never expose to the browser. Looks like: snd_xxx
HYPERSWITCH_API_KEY=snd_replace_me

# Publishable key. Safe to send to the browser. Looks like: pk_snd_xxx
HYPERSWITCH_PUBLISHABLE_KEY=pk_snd_replace_me

# Webhook signing secret. Set the SAME value in the dashboard webhook config.
# Used to verify incoming webhooks are really from Hyperswitch.
HYPERSWITCH_WEBHOOK_SECRET=replace_me_with_a_random_string

# Hyperswitch API base URL (sandbox). Do not change for the prototype.
HYPERSWITCH_BASE_URL=https://sandbox.hyperswitch.io

# Optional. Business profile id (pro_xxx) from the dashboard. Leave blank to use
# your merchant's default profile. Only set this if payment-link creation
# complains about the profile.
HYPERSWITCH_PROFILE_ID=

# Public base URL of THIS app, used to build return_url + webhook URL.
# Local testing: your ngrok tunnel, e.g. https://abcd-1234.ngrok-free.app
# Deployed: your host, e.g. https://subbox.onrender.com
PUBLIC_BASE_URL=http://localhost:4000

# Port this server listens on
PORT=4000

# Integration mode:
#   embedded = we mount the Unified Checkout SDK. Preserves off-session mandate.
#   hosted   = redirect to a Hyperswitch payment link. More robust, but its
#              confirm step drops mandate_data (downgrades to on_session).
CHECKOUT_MODE=embedded
